#!/usr/bin/env python3

from __future__ import annotations

import argparse
import os
import shutil
import sys
from pathlib import Path


REPO_ROOT = Path(__file__).resolve().parent.parent
LICENSE_NAME = "Apache-2.0"

SKILL_MANIFEST = [
    {
        "folder_name": "acf-content-orchestrator",
        "display_name": "ACF Content Orchestrator",
        "source_dir": "skills/content/content-orchestrator",
        "source_id": "content.content-orchestrator",
        "trigger": (
            "When the user asks in natural language to plan, create, package, "
            "or publish content for YouTube, TikTok, or Instagram."
        ),
        "copy_presets": True,
    },
    {
        "folder_name": "acf-topic-research",
        "display_name": "ACF Topic Research",
        "source_dir": "skills/youtube/topic-research",
        "source_id": "youtube.topic-research",
        "trigger": "When the user needs topic ideas, angles, titles, or keyword research for content.",
    },
    {
        "folder_name": "acf-script-writer",
        "display_name": "ACF Script Writer",
        "source_dir": "skills/youtube/script-writer",
        "source_id": "youtube.script-writer",
        "trigger": "When the user needs a script, hook, outline, or CTA for a video.",
